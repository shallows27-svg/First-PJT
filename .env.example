# 운영 도메인 (이메일 확인 redirect 등 신뢰가 필요한 origin 용도)
# Vercel 배포 시 비워두면 VERCEL_PROJECT_PRODUCTION_URL / VERCEL_URL을 자동 사용.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase 프로젝트 설정 (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# OpenRouter (https://openrouter.ai/keys) — 서버 전용, NEXT_PUBLIC_ 금지
OPENROUTER_API_KEY=sk-or-v1-...
# 포트폴리오 요약 + 조언 모델. 기본은 Claude Haiku 4.5 (저렴·빠름). Sonnet으로 올려도 됨.
OPENROUTER_MODEL=anthropic/claude-haiku-4-5
# 스크린샷 OCR 모델 (vision)
OPENROUTER_VISION_MODEL=google/gemini-2.5-flash
